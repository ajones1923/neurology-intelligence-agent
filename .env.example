# =============================================================================
# Neurology Intelligence Agent - Environment Configuration
# Copy this file to .env and set your values
# =============================================================================

# -- Anthropic API Key (required for LLM features) --
ANTHROPIC_API_KEY=sk-ant-your-key-here

# -- Milvus Vector Database --
NEURO_MILVUS_HOST=localhost
NEURO_MILVUS_PORT=19530

# -- Service Ports --
NEURO_API_PORT=8528
NEURO_STREAMLIT_PORT=8529

# -- Embeddings --
NEURO_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# -- LLM --
NEURO_LLM_MODEL=claude-sonnet-4-6

# -- RAG Search --
NEURO_SCORE_THRESHOLD=0.4

# -- Authentication (empty = no auth required) --
NEURO_API_KEY=

# -- CORS --
NEURO_CORS_ORIGINS=http://localhost:8080,http://localhost:8528,http://localhost:8529

# -- Scheduled Ingest (PubMed, Guidelines) --
NEURO_INGEST_ENABLED=false
NEURO_INGEST_SCHEDULE_HOURS=24

# -- External APIs (optional) --
NEURO_CLINICALTRIALS_API_KEY=
NEURO_NCBI_API_KEY=

# -- Prometheus Metrics --
NEURO_METRICS_ENABLED=true

# -- Request Limits --
NEURO_MAX_REQUEST_SIZE_MB=10
